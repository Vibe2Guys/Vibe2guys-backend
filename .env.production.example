POSTGRES_DB=vibe2guys
POSTGRES_USER=vibe2guys
POSTGRES_PASSWORD=replace-with-a-strong-db-password

JWT_SECRET=replace-with-a-long-random-jwt-secret-at-least-32-bytes
JWT_REFRESH_TOKEN_HASH_SECRET=replace-with-a-different-long-random-secret-at-least-32-bytes
BACKOFFICE_ACCESS_KEY=replace-with-a-long-random-backoffice-key

JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600

LOGIN_THROTTLE_MAX_ATTEMPTS=5
LOGIN_THROTTLE_WINDOW_SECONDS=300
LOGIN_THROTTLE_BLOCK_SECONDS=900

SPRING_PROFILES_ACTIVE=prod
SPRINGDOC_SWAGGER_UI_ENABLED=false
SPRINGDOC_API_DOCS_ENABLED=false

APP_EXPOSE_PORT=127.0.0.1:8080
DB_EXPOSE_PORT=127.0.0.1:5432
JAVA_OPTS=-Xms256m -Xmx768m

S3_ENABLED=false
S3_REGION=ap-northeast-2
S3_BUCKET=replace-with-your-s3-bucket
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_UPLOAD_PREFIX=videos
S3_PUBLIC_BASE_URL=
S3_PRESIGN_EXPIRATION_SECONDS=900

AI_RISK_ANALYSIS_ENABLED=false
AI_RISK_ANALYSIS_BASE_URL=https://api.openai.com/v1
AI_RISK_ANALYSIS_API_KEY=
AI_RISK_ANALYSIS_MODEL=gpt-4.1-mini
AI_RISK_ANALYSIS_TEMPERATURE=0.2
AI_RISK_ANALYSIS_TIMEOUT_SECONDS=20
