DB_URL=jdbc:postgresql://localhost:5432/vibe2guys
DB_USERNAME=postgres
DB_PASSWORD=postgres

JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_REFRESH_TOKEN_HASH_SECRET=replace-with-a-different-long-random-hash-secret
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600

LOGIN_THROTTLE_MAX_ATTEMPTS=5
LOGIN_THROTTLE_WINDOW_SECONDS=300
LOGIN_THROTTLE_BLOCK_SECONDS=900
TRUST_PROXY_HEADERS=false
BACKOFFICE_ACCESS_KEY=replace-with-a-long-random-backoffice-key

SPRING_PROFILES_ACTIVE=local
