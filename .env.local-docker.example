POSTGRES_DB=vibe2guys
POSTGRES_USER=vibe2guys
POSTGRES_PASSWORD=vibe2guys-local-db-password

JWT_SECRET=local-docker-test-jwt-secret-should-be-long-and-random-123456
JWT_REFRESH_TOKEN_HASH_SECRET=local-docker-test-refresh-hash-secret-different-654321
BACKOFFICE_ACCESS_KEY=local-docker-test-backoffice-key-1234567890

JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600

LOGIN_THROTTLE_MAX_ATTEMPTS=50
LOGIN_THROTTLE_WINDOW_SECONDS=60
LOGIN_THROTTLE_BLOCK_SECONDS=60
CORS_ALLOWED_ORIGINS=http://localhost:3000

SPRING_PROFILES_ACTIVE=prod
SPRINGDOC_SWAGGER_UI_ENABLED=true
SPRINGDOC_API_DOCS_ENABLED=true

APP_EXPOSE_PORT=127.0.0.1:18080
DB_EXPOSE_PORT=127.0.0.1:15432
JAVA_OPTS=-Xms256m -Xmx768m

S3_ENABLED=false
S3_REGION=ap-northeast-2
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_UPLOAD_PREFIX=videos
S3_PUBLIC_BASE_URL=
S3_PRESIGN_EXPIRATION_SECONDS=900

AI_RISK_ANALYSIS_ENABLED=false
AI_RISK_ANALYSIS_BASE_URL=https://api.openai.com/v1
AI_RISK_ANALYSIS_API_KEY=
AI_RISK_ANALYSIS_MODEL=gpt-4.1-mini
AI_RISK_ANALYSIS_TEMPERATURE=0.2
AI_RISK_ANALYSIS_TIMEOUT_SECONDS=20
